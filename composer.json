{
    "name": "kyzegs/guzzle-rate-limit-middleware",
    "description": "A configurable Guzzle middleware for rate limiting HTTP requests based on response headers",
    "type": "library",
    "keywords": ["guzzle", "middleware", "rate-limit", "http", "api"],
    "license": "MIT",
    "authors": [
        {
            "name": "Sebastiaan",
            "email": "kyzegs@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.10",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "suggest": {
        "psr/simple-cache": "A PSR-16 cache (e.g. Redis, Memcached, Laravel or Symfony cache) for cross-process state via Psr16Store"
    },
    "autoload": {
        "psr-4": {
            "Kyzegs\\GuzzleRateLimitMiddleware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kyzegs\\GuzzleRateLimitMiddleware\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M"
    }
}
